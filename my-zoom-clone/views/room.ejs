<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zoom Clone</title>
    <link rel="stylesheet" href="style.css">
    <script>const ROOM_ID = "<%= roomId %>"; const user = prompt("Enter your name") || "Guest";</script>
    <script src="https://unpkg.com/peerjs@1.5.2/dist/peerjs.min.js" defer></script>
    <script src="/socket.io/socket.io.js" defer></script>
    <script src="script.js" defer></script>
</head>
<body>
    <div class="main">
        <div class="main__left">
            <div id="video-grid"></div>
            <div class="controls">
                <button class="btn" id="video-btn">Stop Video</button>
                <button class="btn" id="copy-link-btn" style="background: #3498db;">Copy Room Link</button>
                <button class="btn" id="leave-btn" style="background: #e74c3c;" onclick="window.location.href='/'">Leave</button>
            </div>
        </div>
        <div class="main__right">
            <h3>CHAT</h3>
            <div id="chat-window"></div>
            <input type="text" id="chat-input" placeholder="Type message...">
        </div>
    </div>
</body>
</html>