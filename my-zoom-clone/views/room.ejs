<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zoom Clone</title>
    <script src="https://unpkg.com/peerjs@1.5.2/dist/peerjs.min.js" defer></script>
    <script src="/socket.io/socket.io.js" defer></script>
    <script src="script.js" defer></script>
    <script>const ROOM_ID = "<%= roomId %>"</script>
    <style>
        body { margin: 0; background: #121212; color: white; font-family: sans-serif; height: 100vh; display: flex; flex-direction: column; }
        .main { display: flex; flex-grow: 1; overflow: hidden; }
        #video-grid { display: grid; grid-template-columns: repeat(auto-fill, 300px); grid-auto-rows: 250px; flex-grow: 1; padding: 20px; gap: 15px; overflow-y: auto; }
        .video-box { position: relative; background: #000; border-radius: 10px; overflow: hidden; border: 2px solid #333; }
        video { width: 100%; height: 100%; object-fit: cover; }
        .name-tag { position: absolute; bottom: 10px; left: 10px; background: #2ecc71; padding: 2px 8px; border-radius: 4px; font-size: 12px; color: black; font-weight: bold; }
        .sidebar { width: 300px; background: #1c1c1c; border-left: 1px solid #333; display: flex; flex-direction: column; }
        #chat-messages { flex-grow: 1; padding: 15px; overflow-y: auto; list-style: none; margin: 0; }
        #chat-messages li { margin-bottom: 10px; padding: 8px; background: #2a2a2a; border-radius: 5px; font-size: 13px; border-left: 3px solid #3498db; }
        .controls { height: 80px; background: #1c1c1c; display: flex; align-items: center; justify-content: center; gap: 15px; border-top: 1px solid #333; }
        .btn { padding: 10px 20px; border-radius: 8px; border: none; cursor: pointer; background: #333; color: white; font-weight: bold; }
        .btn-hand { background: #f1c40f; color: black; }
        .btn-leave { background: #e74c3c; }
    </style>
</head>
<body>
    <div class="main">
        <div id="video-grid"></div>
        <div class="sidebar">
            <div style="padding:15px; border-bottom:1px solid #333; text-align:center; font-weight:bold; letter-spacing:1px">CHAT</div>
            <ul id="chat-messages"></ul>
            <form style="padding:10px" id="chat-form">
                <input id="chat-input" style="width:100%; padding:12px; background:#121212; color:white; border:1px solid #333; border-radius:5px" placeholder="Type message..." autocomplete="off">
            </form>
        </div>
    </div>
    <div class="controls">
        <button class="btn" id="mute-btn">Unmute</button>
        <button class="btn" id="video-btn">Start Video</button>
        <button class="btn btn-hand" id="hand-btn">Raise Hand ✋</button>
        <button class="btn btn-leave" onclick="window.location.href='/'">Leave</button>
    </div>
</body>
</html>